  "keyFeatures": [
    "JWT-based authentication with email verification",
    "Role-based access control (USER_ROLE, ADMIN_ROLE)",
    "Account management with AHORRO and MONETARIA types",
    "Transaction processing with TRANSFERENCIA and DEPOSITO types",
    "Automatic interest generation for savings accounts",
    "Points-based reward system for service redemption",
    "Currency conversion support (USD)",
    "Rate limiting and security middleware",
    "Cloudinary integration for profile images",
    "Email notifications for transactions and verifications",
    "Time-based transaction cancellation (60s window)",
    "Daily transaction limits",
    "Account request approval workflow",
    "Favorites system with account aliases"
  ],
  "publicApiSurface": [
    "POST /api/v1/auth/register - Register new user",
    "POST /api/v1/auth/login - Authenticate user",
    "POST /api/v1/auth/verify-email - Verify email address",
    "POST /api/v1/auth/forgot-password - Request password reset",
    "POST /api/v1/auth/reset-password - Reset password with token",
    "GET /api/v1/auth/profile - Get user profile",
    "PUT /api/v1/auth/profile - Update user profile",
    "GET /api/v1/users - Get all users (admin only)",
    "POST /api/v1/cuentas/create - Create new account",
    "GET /api/v1/cuentas - Get all accounts (admin only)",
    "GET /api/v1/cuentas/buscar/favoritos - Search favorite accounts",
    "PUT /api/v1/cuentas/:id/saldo - Update account balance (admin only)",
    "POST /api/v1/transactions - Create transaction",
    "GET /api/v1/transactions - Get all transactions (admin only)",
    "GET /api/v1/transactions/account/:id_cuenta - Get account transaction history",
    "DELETE /api/v1/transactions/cancelar/:id - Cancel transaction (admin only)",
    "POST /api/v1/deposits - Create deposit",
    "POST /api/v1/withdrawals - Create withdrawal",
    "POST /api/v1/services - Create service (admin only)",
    "GET /api/v1/services - Get all available services",
    "PUT /api/v1/services/:id - Update service (admin only)",
    "DELETE /api/v1/services/:id - Delete service (admin only)",
    "POST /api/v1/redeem_services - Redeem service with points",
    "GET /api/v1/redeem_services - Get redemption history",
    "DELETE /api/v1/redeem_services/:id - Cancel redemption",
    "GET /api/v1/request_accounts - Get account requests (admin only)",
    "PUT /api/v1/request_accounts/:id/approve - Approve account request (admin only)",
    "PUT /api/v1/request_accounts/:id/deny - Deny account request (admin only)",
    "GET /api/v1/health - Health check endpoint"
  ]
}
